# Supabase Postgres – Connection String
# Supabase Dashboard → Project Settings → Database → Connection string
# Für Vercel / Next.js API-Routen: "Transaction" pooler (Port 6543) empfohlen.
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Optional: Google Places API Key (sonst nur OpenStreetMap als Quelle)
GOOGLE_API_KEY=

# Single-Password-Auth (Cookie-basiert)
APP_PASSWORD=
APP_SECRET=

# Sales-Hub-Webhook (optional) – pusht Leads bei Statuswechsel auf
# "interested"/"call_scheduled" an den Volles-Studio-Sales-Hub.
# Bleibt leer = Feature aus (No-Op). Secret z.B. via: openssl rand -hex 32
SALESHUB_WEBHOOK_URL=
SALESHUB_WEBHOOK_SECRET=
# SALESHUB_WEBHOOK_TIMEOUT=3500

# Maschinen-Token: erlaubt dem Sales Hub, per "Authorization: Bearer <token>"
# Leads zu LESEN + Enrichment (Bewertungen etc.) on demand zu triggern.
# Nur Lese-/Enrichment-Endpoints, keine Mutationen. Leer = aus.
SCRAPER_API_TOKEN=

# Cal.com-Buchung im Leadscraper. Nur CALCOM_API_KEY ist Pflicht (leer = aus).
# Denselben Key wie im Sales Hub verwenden, damit alles in einem Kalender landet.
CALCOM_API_KEY=
# Event-Type defaultet auf 6067597 ("Kennenlerngespräch"); nur setzen zum Übersteuern.
# CALCOM_EVENT_TYPE_ID=6067597
# CALCOM_TIMEZONE=Europe/Berlin
# CALCOM_API_VERSION=2024-08-13
