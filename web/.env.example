# Supabase Postgres – Connection String
# Supabase Dashboard → Project Settings → Database → Connection string
# Für Vercel / Next.js API-Routen: "Transaction" pooler (Port 6543) empfohlen.
# Format: postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
DATABASE_URL=

# Optional: Google Places API Key (sonst nur OpenStreetMap als Quelle)
GOOGLE_API_KEY=

# Single-Password-Auth (Cookie-basiert)
APP_PASSWORD=
APP_SECRET=
